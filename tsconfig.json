{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@engine/*": ["src/engine/*"],
      "@stores/*": ["src/stores/*"],
      "@components/*": ["src/components/*"],
      "@/*": ["src/*"]
    },
    "types": ["react-native", "jest"]
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
